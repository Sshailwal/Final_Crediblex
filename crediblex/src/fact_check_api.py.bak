"""
OpenAI API client with real-time web search capability for CredibleX factuality checking.
Provides `check_factuality_with_llm` to check text factuality in real-time.
"""

import os
import re
import json
import logging
from curl_cffi import requests
from bs4 import BeautifulSoup
from config import OPENAI_API_KEY, OPENAI_MODEL

logger = logging.getLogger(__name__)

_ENDPOINT = "https://api.openai.com/v1/chat/completions"

def search_duckduckgo(query: str) -> list[str]:
    """
    Search DuckDuckGo using curl_cffi to bypass bot protection and return top 5 snippets.
    """
    try:
        # Clean query: keep alphanumeric words and spaces, limit length
        clean_q = re.sub(r'[^\w\s-]', ' ', query)
        words = clean_q.split()
        if not words:
            return []
        search_query = " ".join(words[:15])
        
        # URL encode query
        from urllib.parse import quote
        url = f"https://html.duckduckgo.com/html/?q={quote(search_query)}"
        
        headers = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        }
        
        response = requests.get(url, headers=headers, timeout=10)
        if response.status_code == 200:
            soup = BeautifulSoup(response.text, 'html.parser')
            snippets = []
            for a in soup.find_all('a', class_='result__snippet'):
                snippet_text = a.text.strip()
                if snippet_text:
                    snippets.append(snippet_text)
            return snippets[:5]
        else:
            logger.warning(f"DuckDuckGo search returned status code {response.status_code}")
    except Exception as e:
        logger.error(f"Failed to fetch DuckDuckGo search results: {e}")
    return []

def check_factuality_with_llm(text: str) -> dict | None:
    """
    Call the OpenAI Chat Completions API in JSON mode to verify the factuality of the text,
    incorporating real-time web search results for recent event verification.
    
    Args:
        text: The raw article or message text.
        
    Returns:
        A dict containing:
            - 'factuality_score': float (0.0 to 1.0)
            - 'label': str ('true', 'mostly_true', 'half_true', 'barely_true', 'false')
            - 'explanation': str (a short summary)
            - 'findings': list of dicts (each having keys 'type', 'icon', 'text')
        Or None if OpenAI API key is not set, or an API error occurs.
    """
    if not OPENAI_API_KEY or OPENAI_API_KEY == "your_openai_api_key_here":
        logger.warning("OpenAI API key is not configured. Skipping LLM check.")
        return None

    # Determine query for DuckDuckGo
    lines = [line.strip() for line in text.splitlines() if line.strip()]
    if lines:
        first_line = lines[0]
        if len(first_line) < 30 and len(lines) > 1:
            query = f"{first_line} {lines[1]}"
        else:
            query = first_line
    else:
        query = text
    query = query[:150].strip()

    # Retrieve real-time search results
    search_results = search_duckduckgo(query) if query else []

    system_prompt = (
        "You are an expert fact-checker. Analyze the given text/article and evaluate its veracity/factuality.\n"
        "To help you verify recent events or claims after your knowledge cutoff, you are provided with real-time web search snippets.\n"
        "Verify if the claim is supported by these search results. You must return your analysis as a JSON object with the exact following keys:\n"
        "- 'factuality_score': a float between 0.0 and 1.0 (where 0.0 is completely false/fabricated misinformation/fake news, and 1.0 is completely true/verified facts).\n"
        "- 'label': a string verdict from these exact options: 'true', 'mostly_true', 'half_true', 'barely_true', 'false'.\n"
        "- 'explanation': a short 2-3 sentence explanation summarizing your analysis, referencing the web search findings if applicable.\n"
        "- 'findings': a list of objects representing key findings (maximum 3 findings). Each finding must contain:\n"
        "  - 'type': one of 'good', 'warn', 'bad', 'info'\n"
        "  - 'icon': a single appropriate emoji (e.g. ✅, ⚠️, 🚨, 💬)\n"
        "  - 'text': a description of the specific verified claim or debunked lie."
    )

    headers = {
        "Authorization": f"Bearer {OPENAI_API_KEY}",
        "Content-Type": "application/json"
    }

    user_content = f"Analyze this text:\n\n{text[:8000]}\n\n"
    if search_results:
        user_content += "Here are the real-time search results from the web for reference:\n"
        for i, snippet in enumerate(search_results, 1):
            user_content += f"[{i}] {snippet}\n"

    payload = {
        "model": OPENAI_MODEL,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_content}
        ],
        "temperature": 0.0,
        "response_format": {"type": "json_object"}
    }

    try:
        response = requests.post(
            _ENDPOINT,
            headers=headers,
            json=payload,
            timeout=15,
        )
        response.raise_for_status()
        data = response.json()
        content_str = data["choices"][0]["message"]["content"].strip()
        result = json.loads(content_str)
        
        # Validation and cleaning of LLM output
        score = float(result.get("factuality_score", 0.5))
        score = max(0.0, min(1.0, score))
        
        label = result.get("label", "half_true")
        if label not in ["true", "mostly_true", "half_true", "barely_true", "false"]:
            label = "half_true"
            
        explanation = result.get("explanation", "Could not generate explanation.")
        findings = result.get("findings", [])
        cleaned_findings = []
        for f in findings:
            if isinstance(f, dict) and "text" in f:
                cleaned_findings.append({
                    "type": f.get("type", "info"),
                    "icon": f.get("icon", "💬"),
                    "text": f["text"]
                })
        
        return {
            "factuality_score": score,
            "label": label,
            "explanation": explanation,
            "findings": cleaned_findings
        }
    except Exception as e:
        logger.error(f"Error querying OpenAI API for fact-checking: {e}")
        return None
